model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US

	annotation __PBI_TimeIntelligenceEnabled = 0

expression 'DirectLake - aw_gold' =
		let
		    Source = AzureStorage.DataLake("https://onelake.dfs.fabric.microsoft.com/f6894d78-6eeb-4014-a9ec-3e75ebe36ee8/0b09704d-576a-4f87-8321-741e6d791735", [HierarchicalNavigation=true])
		in
		    Source
	lineageTag: bb12c257-8a1d-424f-b22d-d0fe1f014ea5

ref table 'Product'
ref table 'Reseller'
ref table 'Salesperson'
ref table 'Region'
ref table 'Date'
ref table 'Salesperson Region'
ref table 'Sales'
ref table 'Targets'
