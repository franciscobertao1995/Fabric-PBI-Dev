/// Date dimension: contiguous daily calendar spanning the sales and targets date range. Marked as the model's date table.
table 'Date'
	dataCategory: Time

	column 'Date'
		dataType: dateTime
		formatString: General Date
		summarizeBy: none
		sourceColumn: date

	/// Calendar year number.
	column 'Year'
		dataType: int64
		formatString: 0
		summarizeBy: none
		sourceColumn: year

	/// Calendar quarter number (1-4).
	column 'Quarter'
		dataType: int64
		formatString: 0
		summarizeBy: none
		sourceColumn: quarter

	/// Month number (1-12). Used to sort Month Name chronologically.
	column 'Month Number'
		dataType: int64
		isHidden
		formatString: 0
		summarizeBy: none
		sourceColumn: month

	/// Full month name (e.g. January). Sorted by Month Number.
	column 'Month'
		dataType: string
		summarizeBy: none
		sourceColumn: month_name
		sortByColumn: 'Month Number'

	/// Year and month in yyyy-MM format.
	column 'Year Month'
		dataType: string
		summarizeBy: none
		sourceColumn: year_month

	hierarchy 'Calendar'

		level 'Year'
			column: 'Year'

		level 'Quarter'
			column: 'Quarter'

		level 'Month'
			column: 'Month'

	partition 'Date' = entity
		mode: directLake
		source
			entityName: dim_date
			expressionSource: 'DirectLake - aw_gold'
