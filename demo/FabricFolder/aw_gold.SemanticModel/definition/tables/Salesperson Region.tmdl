/// Bridge table resolving the many-to-many relationship between salespeople and the sales territories they cover.
table 'Salesperson Region'

	/// Foreign key linking to the Salesperson dimension. One side of the many-to-many salesperson-territory relationship.
	column 'Employee Key'
		dataType: int64
		isHidden
		formatString: 0
		summarizeBy: none
		sourceColumn: employee_key

	/// Foreign key linking to the Region dimension. Other side of the many-to-many salesperson-territory relationship.
	column 'Sales Territory Key'
		dataType: int64
		isHidden
		formatString: 0
		summarizeBy: none
		sourceColumn: salesterritory_key

	partition 'Salesperson Region' = entity
		mode: directLake
		source
			entityName: bridge_salesperson_region
			schemaName: dbo
			expressionSource: 'DirectLake - aw_gold'
